<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sequence for Sale Orders -->
    <data noupdate="1">
        <record id="seq_store_sale" model="ir.sequence">
            <field name="name">Store Sale Order</field>
            <field name="code">store.sale</field>
            <field name="prefix">SO-%(year)s%(month)s-</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Default Product Categories -->
        <record id="category_cleaning" model="store.product.category">
            <field name="name">อุปกรณ์ทำความสะอาด</field>
            <field name="sequence">1</field>
        </record>
        <record id="category_kitchen" model="store.product.category">
            <field name="name">อุปกรณ์ในครัว</field>
            <field name="sequence">2</field>
        </record>
        <record id="category_bathroom" model="store.product.category">
            <field name="name">อุปกรณ์ห้องน้ำ</field>
            <field name="sequence">3</field>
        </record>
        <record id="category_bedroom" model="store.product.category">
            <field name="name">อุปกรณ์ห้องนอน</field>
            <field name="sequence">4</field>
        </record>
        <record id="category_electrical" model="store.product.category">
            <field name="name">เครื่องใช้ไฟฟ้า</field>
            <field name="sequence">5</field>
        </record>
        <record id="category_stationery" model="store.product.category">
            <field name="name">เครื่องเขียน</field>
            <field name="sequence">6</field>
        </record>
        <record id="category_general" model="store.product.category">
            <field name="name">ของใช้ทั่วไป</field>
            <field name="sequence">7</field>
        </record>
    </data>

</odoo>
