<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Product -->
        <record id="seq_store_product" model="ir.sequence">
            <field name="name">Product Sequence</field>
            <field name="code">store.product</field>
            <field name="prefix">PRD</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Customer -->
        <record id="seq_store_customer" model="ir.sequence">
            <field name="name">Customer Sequence</field>
            <field name="code">store.customer</field>
            <field name="prefix">CUS</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Employee -->
        <record id="seq_store_employee" model="ir.sequence">
            <field name="name">Employee Sequence</field>
            <field name="code">store.employee</field>
            <field name="prefix">EMP</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
