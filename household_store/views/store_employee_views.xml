<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Employee List View -->
        <record id="store_employee_view_list" model="ir.ui.view">
            <field name="name">store.employee.view.list</field>
            <field name="model">store.employee</field>
            <field name="arch" type="xml">
                <list string="พนักงาน">
                    <field name="employee_code"/>
                    <field name="name"/>
                    <field name="position" widget="badge"/>
                    <field name="department"/>
                    <field name="phone"/>
                    <field name="hire_date"/>
                    <field name="sale_count"/>
                    <field name="total_sales"/>
                </list>
            </field>
        </record>

        <!-- Employee Form View -->
        <record id="store_employee_view_form" model="ir.ui.view">
            <field name="name">store.employee.view.form</field>
            <field name="model">store.employee</field>
            <field name="arch" type="xml">
                <form string="พนักงาน">
                    <header>
                        <button name="unlink" type="object" string="ลบข้อมูลพนักงานนี้" class="btn-danger" confirm="ยืนยันการลบข้อมูลพนักงานนี้แบบถาวร?"/>
                    </header>
                    <sheet>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="ชื่อ-นามสกุล"/>
                            </h1>
                            <h3>
                                <field name="employee_code" placeholder="รหัสพนักงาน"/>
                            </h3>
                        </div>
                        <group>
                            <group string="ข้อมูลส่วนตัว">
                                <field name="phone" widget="phone"/>
                                <field name="email" widget="email"/>
                                <field name="address"/>
                            </group>
                            <group string="ข้อมูลงาน">
                                <field name="position"/>
                                <field name="department"/>
                                <field name="hire_date"/>
                                <field name="salary"/>
                                <field name="active" invisible="1"/>
                            </group>
                        </group>
                        <group string="ผลงานการขาย">
                            <group>
                                <field name="sale_count"/>
                            </group>
                            <group>
                                <field name="total_sales"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="รายการขาย">
                                <field name="sale_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="sale_date"/>
                                        <field name="customer_id"/>
                                        <field name="total_amount"/>
                                        <field name="state" widget="badge"/>
                                    </list>
                                </field>
                            </page>
                            <page string="หมายเหตุ">
                                <field name="notes" placeholder="หมายเหตุเพิ่มเติม..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Employee Kanban View -->
        <record id="store_employee_view_kanban" model="ir.ui.view">
            <field name="name">store.employee.view.kanban</field>
            <field name="model">store.employee</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="image"/>
                    <templates>
                        <t t-name="card" class="flex-row shadow-sm rounded-3">
                            <aside class="o_kanban_aside_full">
                                <t t-if="record.image.raw_value">
                                    <field name="image" widget="image" options="{'size': [90, 90]}"/>
                                </t>
                                <div t-else="" class="d-flex align-items-center justify-content-center bg-100 bg-gradient" style="width:90px;height:90px;">
                                    <i class="fa fa-id-badge fa-3x text-muted opacity-50"/>
                                </div>
                            </aside>
                            <main class="ms-3 py-2 d-flex flex-column justify-content-center">
                                <field name="name" class="fw-bolder fs-5 text-dark mb-1"/>
                                <div class="text-muted small mb-1">
                                    <i class="fa fa-phone me-1"/>
                                    <field name="phone" widget="phone"/>
                                </div>
                                <div class="d-flex align-items-center mt-auto gap-2">
                                    <field name="position" widget="badge"/>
                                    <div class="text-muted small">
                                        <i class="fa fa-hashtag me-1"/>
                                        <field name="employee_code"/>
                                    </div>
                                </div>
                            </main>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Employee Action -->
        <record id="action_store_employee" model="ir.actions.act_window">
            <field name="name">พนักงาน</field>
            <field name="res_model">store.employee</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="search_view_id" ref="store_employee_view_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                เพิ่มพนักงานคนแรก
                </p>
            </field>
        </record>

        <!-- Employee Search View -->
        <record id="store_employee_view_search" model="ir.ui.view">
            <field name="name">store.employee.view.search</field>
            <field name="model">store.employee</field>
            <field name="arch" type="xml">
                <search string="ค้นหาพนักงาน">
                    <field name="name"/>
                    <field name="employee_code"/>
                    <field name="phone"/>
                    <separator/>
                    <filter string="ผู้จัดการ" name="manager" domain="[('position','=','manager')]"/>
                    <filter string="แคชเชียร์" name="cashier" domain="[('position','=','cashier')]"/>
                    <filter string="พนักงานขาย" name="sales" domain="[('position','=','sales')]"/>
                    <separator/>
                    <filter string="ไม่ใช้งาน" name="inactive" domain="[('active','=',False)]"/>
                    <group>
                        <filter string="ตำแหน่ง" name="group_position" domain="[]" context="{'group_by': 'position'}"/>
                        <filter string="แผนก" name="group_department" domain="[]" context="{'group_by': 'department'}"/>
                    </group>
                </search>
            </field>
        </record>

    </data>
</odoo>
