<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Product Category List View -->
        <record id="store_product_category_view_list" model="ir.ui.view">
            <field name="name">store.product.category.view.list</field>
            <field name="model">store.product.category</field>
            <field name="arch" type="xml">
                <list string="หมวดหมู่สินค้า" editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="description"/>
                    <field name="product_count"/>
                </list>
            </field>
        </record>

        <record id="action_store_product_category" model="ir.actions.act_window">
            <field name="name">หมวดหมู่สินค้า</field>
            <field name="res_model">store.product.category</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Product List View -->
        <record id="store_product_view_list" model="ir.ui.view">
            <field name="name">store.product.view.list</field>
            <field name="model">store.product</field>
            <field name="arch" type="xml">
                <list string="สินค้า" decoration-danger="stock_status=='out_of_stock'" decoration-warning="stock_status=='low_stock'" decoration-muted="stock_status=='out_of_stock'">
                    <field name="product_code" class="fw-bold"/>
                    <field name="name"/>
                    <field name="category_id"/>
                    <field name="cost_price" optional="hide"/>
                    <field name="sale_price"/>
                    <field name="profit_margin" optional="hide"/>
                    <field name="quantity_on_hand" decoration-success="quantity_on_hand &gt; minimum_stock" decoration-warning="quantity_on_hand &lt;= minimum_stock" decoration-danger="quantity_on_hand == 0"/>
                    <field name="unit" optional="show"/>
                    <field name="stock_status" widget="badge" decoration-success="stock_status=='in_stock'" decoration-warning="stock_status=='low_stock'" decoration-danger="stock_status=='out_of_stock'"/>
                </list>
            </field>
        </record>

        <!-- Product Form View -->
        <record id="store_product_view_form" model="ir.ui.view">
            <field name="name">store.product.view.form</field>
            <field name="model">store.product</field>
            <field name="arch" type="xml">
                <form string="สินค้า">
                    <header>
                        <button name="unlink" type="object" string="ลบข้อมูลสินค้านี้" class="btn-danger" confirm="ยืนยันการลบข้อมูลสินค้านี้แบบถาวร?"/>
                        <field name="stock_status" widget="statusbar" statusbar_visible="in_stock,low_stock,out_of_stock"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="มีสินค้า" bg_color="text-bg-success" invisible="stock_status != 'in_stock'"/>
                        <widget name="web_ribbon" title="ใกล้หมด" bg_color="text-bg-warning" invisible="stock_status != 'low_stock'"/>
                        <widget name="web_ribbon" title="สินค้าหมด" bg_color="text-bg-danger" invisible="stock_status != 'out_of_stock'"/>

                        <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image', 'size': [128, 128]}"/>
                        <div class="oe_title">
                            <label for="name" string="ชื่อสินค้า"/>
                            <h1>
                                <field name="name" placeholder="เช่น โต๊ะทำงานไม้โอ๊ค" default_focus="1"/>
                            </h1>
                            <div class="o_row">
                                <field name="product_code" placeholder="รหัสสินค้า" class="fw-bold"/>
                                <span class="ps-2 pe-2 text-muted">|</span>
                                <field name="category_id" placeholder="หมวดหมู่"/>
                            </div>
                        </div>

                        <notebook>
                            <page string="ข้อมูลทั่วไป" name="general_info">
                                <group>
                                    <group>
                                        <field name="barcode"/>
                                        <field name="unit"/>
                                    </group>
                                    <group>
                                        <field name="cost_price"/>
                                        <field name="sale_price"/>
                                        <field name="profit_margin"/>
                                        <field name="profit_percentage" widget="percentage"/>
                                    </group>
                                </group>
                                <label for="description" class="mt-3 fw-bold" string="รายละเอียดเพิ่มเติม"/>
                                <field name="description" placeholder="รายละเอียดสินค้าเพิ่มเติม..."/>
                            </page>
                            <page string="ข้อมูลสต็อก" name="stock_info">
                                <group>
                                    <group>
                                        <field name="quantity_on_hand"/>
                                        <field name="minimum_stock"/>
                                    </group>
                                    <group>
                                        <field name="stock_status" widget="badge" decoration-success="stock_status=='in_stock'" decoration-warning="stock_status=='low_stock'" decoration-danger="stock_status=='out_of_stock'"/>
                                    </group>
                                </group>
                            </page>
                            <page string="หมายเหตุ" name="notes">
                                <field name="notes" placeholder="บันทึกข้อความภายใน..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Product Search View -->
        <record id="store_product_view_search" model="ir.ui.view">
            <field name="name">store.product.view.search</field>
            <field name="model">store.product</field>
            <field name="arch" type="xml">
                <search string="ค้นหาสินค้า">
                    <field name="name"/>
                    <field name="product_code"/>
                    <field name="category_id"/>
                    <separator/>
                    <filter string="มีสินค้า" name="in_stock" domain="[('stock_status','=','in_stock')]"/>
                    <filter string="สินค้าใกล้หมด" name="low_stock" domain="[('stock_status','=','low_stock')]"/>
                    <filter string="สินค้าหมด" name="out_of_stock" domain="[('stock_status','=','out_of_stock')]"/>
                    <group>
                        <filter string="หมวดหมู่" name="group_category" domain="[]" context="{'group_by': 'category_id'}"/>
                        <filter string="สถานะสต็อก" name="group_stock" domain="[]" context="{'group_by': 'stock_status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Product Kanban View -->
        <record id="store_product_view_kanban" model="ir.ui.view">
            <field name="name">store.product.view.kanban</field>
            <field name="model">store.product</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="image"/>
                    <field name="id"/>
                    <field name="name"/>
                    <field name="product_code"/>
                    <field name="category_id"/>
                    <field name="sale_price"/>
                    <field name="cost_price"/>
                    <field name="quantity_on_hand"/>
                    <field name="unit"/>
                    <field name="stock_status"/>
                    <templates>
                        <t t-name="card" class="flex-row o_kanban_record_has_image_fill shadow-sm rounded-3">
                            <div class="o_kanban_image d-flex align-items-center justify-content-center bg-light rounded-start-3" style="width: 100px; height: 100px; overflow: hidden;">
                                <t t-if="record.image.raw_value">
                                    <field name="image" widget="image" options="{'size': [100, 100]}" class="rounded-3 w-100 h-100 object-fit-cover"/>
                                </t>
                                <t t-else="">
                                    <i class="fa fa-cube fa-3x text-muted opacity-50"/>
                                </t>
                            </div>
                            <div class="oe_kanban_details ms-3 py-2 d-flex flex-column justify-content-between">
                                <div>
                                    <strong class="o_kanban_record_title fs-5 text-dark">
                                        <field name="name"/>
                                    </strong>
                                    <div class="text-muted small mt-1">
                                        <i class="fa fa-barcode me-1"/>
                                        <field name="product_code"/>
 | 
                                        <i class="fa fa-folder-open me-1"/>
                                        <field name="category_id"/>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    <div class="fw-bold text-primary mb-1 fs-6">฿                                        <field name="sale_price"/>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="small text-muted">
                                            <i class="fa fa-cubes me-1"/>
 คงเหลือ:                                            <strong class="text-dark">
                                                <field name="quantity_on_hand"/>
                                            </strong>
                                            <field name="unit"/>
                                        </span>
                                        <field name="stock_status" widget="badge" decoration-success="stock_status=='in_stock'" decoration-warning="stock_status=='low_stock'" decoration-danger="stock_status=='out_of_stock'"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_store_product" model="ir.actions.act_window">
            <field name="name">สินค้า</field>
            <field name="res_model">store.product</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="search_view_id" ref="store_product_view_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">เพิ่มสินค้าชิ้นแรก</p>
            </field>
        </record>

    </data>
</odoo>
