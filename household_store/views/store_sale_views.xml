<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Sale Order List View -->
        <record id="store_sale_view_list" model="ir.ui.view">
            <field name="name">store.sale.view.list</field>
            <field name="model">store.sale</field>
            <field name="arch" type="xml">
                <list string="รายการขาย" decoration-info="state=='draft'" decoration-success="state=='confirmed'" decoration-danger="state=='cancelled'" decoration-muted="state=='cancelled'" default_order="sale_date desc">
                    <field name="name" class="fw-bold"/>
                    <field name="sale_date" widget="date"/>
                    <field name="customer_id" string="ลูกค้า / รหัสลูกค้า"/>
                    <field name="employee_id" string="พนักงานขาย / รหัสพนักงาน" optional="show"/>
                    <field name="line_count" optional="hide"/>
                    <field name="total_amount" optional="hide"/>
                    <field name="discount" optional="hide"/>
                    <field name="net_total" class="fw-bold text-primary"/>
                    <field name="payment_method" widget="badge" decoration-info="payment_method=='transfer'" decoration-warning="payment_method=='credit'" decoration-success="payment_method=='cash'"/>
                    <field name="state" widget="badge" decoration-success="state=='confirmed'" decoration-info="state=='draft'" decoration-danger="state=='cancelled'"/>
                </list>
            </field>
        </record>

        <!-- Sale Order Form View -->
        <record id="store_sale_view_form" model="ir.ui.view">
            <field name="name">store.sale.view.form</field>
            <field name="model">store.sale</field>
            <field name="arch" type="xml">
                <form string="ใบขาย">
                    <header>
                        <button name="action_confirm" type="object" string="ยืนยันการขาย" class="btn-primary" invisible="state != 'draft'" icon="fa-check"/>
                        <button name="action_cancel" type="object" string="ยกเลิก" class="btn-secondary" invisible="state != 'draft' and state != 'confirmed'"/>
                        <button name="action_draft" type="object" string="ตั้งเป็นร่าง" invisible="state != 'cancelled'"/>
                        <button name="action_clear_lines" type="object" string="ล้างรายการทั้งหมด" class="btn-warning" confirm="ยืนยันการลบรายการสินค้าทั้งหมดในใบขายนี้?" invisible="state != 'draft'"/>
                        <button name="unlink" type="object" string="ลบใบขายนี้" class="btn-danger" confirm="ยืนยันการลบใบขายนี้แบบถาวร?" invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="ยืนยันแล้ว" bg_color="text-bg-success" invisible="state != 'confirmed'"/>
                        <widget name="web_ribbon" title="ยกเลิกแล้ว" bg_color="text-bg-danger" invisible="state != 'cancelled'"/>
                        <widget name="web_ribbon" title="ฉบับร่าง" bg_color="text-bg-info" invisible="state != 'draft'"/>

                        <div class="oe_title">
                            <label for="name" string="เลขที่ใบขาย" invisible="state == 'draft'"/>
                            <h1>
                                <field name="name" readonly="1" invisible="state == 'draft'"/>
                                <span invisible="state != 'draft'" class="text-muted">ใบขายใหม่</span>
                            </h1>
                        </div>

                        <group>
                            <group string="ข้อมูลลูกค้า">
                                <field name="customer_id" string="ลูกค้า / รหัสลูกค้า"/>
                                <field name="sale_date"/>
                            </group>
                            <group string="การชำระเงินและพนักงาน">
                                <field name="payment_method" widget="radio" options="{'horizontal': true}"/>
                                <field name="employee_id" string="พนักงานขาย / รหัสพนักงาน"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="รายการสินค้า" name="order_lines">
                                <field name="line_ids" widget="section_and_note_one2many" mode="list">
                                    <list editable="bottom" decoration-info="product_id">
                                        <field name="sequence" widget="handle"/>
                                        <field name="product_id"/>
                                        <field name="quantity"/>
                                        <field name="unit_price"/>
                                        <field name="cost_price" column_invisible="1"/>
                                        <field name="subtotal" class="fw-bold"/>
                                    </list>
                                </field>
                                <group class="oe_subtotal_footer oe_right" colspan="2" name="sale_total">
                                    <field name="total_amount"/>
                                    <field name="discount"/>
                                    <div class="oe_subtotal_footer_separator oe_inline o_td_label">
                                        <label for="net_total"/>
                                    </div>
                                    <field name="net_total" nolabel="1" class="oe_subtotal_footer_separator fw-bold text-primary fs-3"/>
                                </group>
                            </page>
                            <page string="หมายเหตุ" name="notes">
                                <field name="notes" placeholder="เพิ่มหมายเหตุข้อตกลง หรือรายละเอียดเพิ่มเติมเกี่ยวกับการขายนี้..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Sale Search View -->
        <record id="store_sale_view_search" model="ir.ui.view">
            <field name="name">store.sale.view.search</field>
            <field name="model">store.sale</field>
            <field name="arch" type="xml">
                <search string="ค้นหาใบขาย">
                    <field name="name"/>
                    <field name="customer_id"/>
                    <field name="employee_id"/>
                    <separator/>
                    <filter string="ร่าง" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="ยืนยันแล้ว" name="confirmed" domain="[('state','=','confirmed')]"/>
                    <filter string="ยกเลิก" name="cancelled" domain="[('state','=','cancelled')]"/>
                    <group>
                        <filter string="ลูกค้า" name="group_customer" domain="[]" context="{'group_by': 'customer_id'}"/>
                        <filter string="พนักงาน" name="group_employee" domain="[]" context="{'group_by': 'employee_id'}"/>
                        <filter string="สถานะ" name="group_state" domain="[]" context="{'group_by': 'state'}"/>
                        <filter string="วิธีชำระเงิน" name="group_payment" domain="[]" context="{'group_by': 'payment_method'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Sale Action -->
        <record id="action_store_sale" model="ir.actions.act_window">
            <field name="name">รายการขาย</field>
            <field name="res_model">store.sale</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="store_sale_view_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">สร้างใบขายใหม่</p>
            </field>
        </record>

    </data>
</odoo>
