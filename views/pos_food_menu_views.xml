<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_pos_food_menu_form" model="ir.ui.view">
            <field name="name">pos.food.menu.form</field>
            <field name="model">pos.food.menu</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <group>
                            <field name="name" string="ชื่ออาหาร"/>
                            <field name="category" string="หมวดหมู่"/>
                            <field name="price" string="ราคา"/>
                            <field name="is_available" string="พร้อมจำหน่าย"/>
                        </group>
                        <notebook>
                            <page string="สูตรอาหาร (วัตถุดิบที่ใช้)">
                                <field name="recipe_line_ids">
                                    <list editable="bottom">
                                        <field name="ingredient_id"/>
                                        <field name="quantity_required"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_pos_food_menu_tree" model="ir.ui.view">
            <field name="name">pos.food.menu.tree</field>
            <field name="model">pos.food.menu</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name" string="ชื่ออาหาร"/>
                    <field name="category" string="หมวดหมู่"/>
                    <field name="price" string="ราคา"/>
                    <field name="is_available" string="พร้อมจำหน่าย"/>
                </list>
            </field>
        </record>

        <record id="action_pos_food_menu" model="ir.actions.act_window">
            <field name="name">รายการอาหาร</field>
            <field name="res_model">pos.food.menu</field>
            <field name="view_mode">kanban,list,form</field>
        </record>

        <!-- Kanban View -->
        <record id="view_pos_food_menu_kanban" model="ir.ui.view">
            <field name="name">pos.food.menu.kanban</field>
            <field name="model">pos.food.menu</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="id"/>
                    <field name="name"/>
                    <field name="image"/>
                    <field name="price"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click" style="border-radius: 10px; padding: 10px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                                <div style="width: 100px; height: 100px; margin-bottom: 10px; border-radius: 10px; overflow: hidden; display: flex; align-items: center; justify-content: center; background-color: #f0f0f0;">
                                    <field name="image" widget="image" options="{'size': [100, 100]}"/>
                                </div>
                                <div style="text-align: center;">
                                    <strong style="font-size: 16px; display: block; margin-bottom: 4px;">
                                        <field name="name"/>
                                    </strong>
                                    <span style="color: #28a745; font-weight: bold; font-size: 14px;">฿                                        <field name="price"/>
                                    </span>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- สร้างเมนูหลัก (Root Menu) ที่จะไปโผล่ในหน้า Dropdown ตามรูป -->
        <menuitem id="menu_pos_food_root" name="ร้านอาหาร (POS Food)" sequence="50"/>

        <!-- เอาเมนูรายการอาหารไปใส่ใต้เมนูหลักร้านอาหาร -->
        <menuitem id="menu_pos_food_menu" name="จัดการเมนูอาหาร" action="action_pos_food_menu" parent="menu_pos_food_root" sequence="10"/>
    </data>
</odoo>